# ==========================================
# Claude API 設定（必須）
# ==========================================
# Anthropic Console で取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 使用するモデル
CLAUDE_MODEL=claude-sonnet-4-6

# ==========================================
# サーバー設定
# ==========================================
HOST=0.0.0.0
PORT=8000

# ==========================================
# 画像設定
# ==========================================
# アップロード許可ファイルサイズ上限（バイト）デフォルト: 10MB
MAX_UPLOAD_SIZE=10485760

# 画像リサイズ上限（px）- Claude Vision 推奨値
MAX_IMAGE_SIZE=1568

# アップロードディレクトリ（backend/ 以下の相対パス）
UPLOAD_DIR=uploads

# ==========================================
# 抽出設定
# ==========================================
# Claude への応答言語指定（ja / en）
EXTRACTION_LANGUAGE=ja
